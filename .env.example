# Supabase - Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google reCAPTCHA v2 - Get from https://www.google.com/recaptcha/admin
# Leave empty to use test key (always passes)
VITE_RECAPTCHA_SITE_KEY=

# OTP via Twilio - Set as Supabase Edge Function secrets (not in .env.local):
# supabase secrets set TWILIO_ACCOUNT_SID=xxx TWILIO_AUTH_TOKEN=xxx TWILIO_PHONE_NUMBER=+1234567890
# Deploy: supabase functions deploy send-otp && supabase functions deploy verify-otp
