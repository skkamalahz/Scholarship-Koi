# Supabase - Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# For OTP API (Vercel serverless) - Add these in Vercel Dashboard > Settings > Environment Variables:
# VITE_SUPABASE_URL - same as above (or SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY - from Supabase Settings > API (service_role key, keep secret!)
# TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_PHONE_NUMBER - optional, for SMS. Without Twilio, OTP is logged in Vercel function logs.
